$HOME/.config/waybar/theme.css|${scrDir}/wbarconfgen.sh
/* To enable blur please make sure alpha is greater than 0 */
@define-color bar-bg rgba(0, 0, 0, 0.1); 

@define-color main-bg #201b25;
@define-color main-fg #be9eb5;

@define-color wb-act-bg #d2546a;
@define-color wb-act-fg #201b25;

@define-color wb-hvr-bg #b74258;
@define-color wb-hvr-fg #201b25;
